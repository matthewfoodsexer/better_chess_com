{
  "manifest_version": 3,
  "name": "Chess Better",
  "version": "0.1.0",
  "description": "Ad blocker and opponent info for chess.com",
  "host_permissions": [
    "https://api.chess.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.chess.com/*"],
      "css": ["theme.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
