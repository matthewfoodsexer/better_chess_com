{
  "manifest_version": 3,
  "name": "Chess Better",
  "version": "1.1.0",
  "description": "Opponent info widget for chess.com & lichess.org + ad blocker",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://api.chess.com/*", "*://lichess.org/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.chess.com/*", "*://*.lichess.org/*"],
      "css": ["widget.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
